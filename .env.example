# ─── FundFlow AI — Environment Configuration ─────────────────────────────────
# Copy this file to `.env` and adjust values for your environment.

# ─── API Configuration ────────────────────────────────────────────────────────
# Leave FUNDFLOW_API_KEY empty to disable authentication (dev mode only!)
FUNDFLOW_API_KEY=

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fundflow_pass

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fundflow
POSTGRES_USER=fundflow
POSTGRES_PASSWORD=fundflow_pass

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Feedback Storage ────────────────────────────────────────────────────────
# Path to feedback JSON store (swap for PostgreSQL in production)
# FEEDBACK_STORAGE=./feedback_store.json

# ─── API Ports ────────────────────────────────────────────────────────────────
RISK_SCORING_PORT=8000
FEEDBACK_API_PORT=8001
